<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_margin="8dp">

    <TextView
        android:id="@+id/practice_name_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Требуемые документы:"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginTop="12dp" />

    <!-- Антиплагиат -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Антиплагиат"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_antip_lagiat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Загрузить" />

        <TextView
            android:id="@+id/tv_antip_lagiat_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@android:color/holo_green_dark"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Пояснительная записка -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Пояснительная записка"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_poyasnitelnaya"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Загрузить" />

        <TextView
            android:id="@+id/tv_poyasnitelnaya_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@android:color/holo_green_dark"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>